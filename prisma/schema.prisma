generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Region {
  Americas
  Pacific
  EMEA
  China
}

enum PlayerRole {
  Duelist
  Initiator
  Controller
  Sentinel
}

enum LeagueStatus {
  SETUP
  DRAFTING
  ACTIVE
  COMPLETED
}

enum DraftStatus {
  WAITING
  IN_PROGRESS
  COMPLETE
}

enum SlotType {
  Duelist
  Initiator
  Controller
  Sentinel
  Wildcard
}

enum TradeStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum TradeItemSide {
  OFFERED
  REQUESTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  createdLeagues     League[]          @relation("LeagueCreator")
  leagueMemberships  LeagueMember[]
  draftPicks         DraftPick[]
  draftQueueEntries  DraftQueueEntry[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model League {
  id            String       @id @default(cuid())
  name          String       @db.VarChar(50)
  inviteCode    String       @unique @db.VarChar(8)
  status        LeagueStatus @default(SETUP)
  creatorId     String
  rosterSize    Int          @default(10)
  draftPickTime Int          @default(60)
  currentWeek   Int          @default(1)
  archivedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  creator          User               @relation("LeagueCreator", fields: [creatorId], references: [id])
  members          LeagueMember[]
  rosters          Roster[]
  draft            DraftState?
  weeks            LeagueWeek[]
  draftQueueEntries DraftQueueEntry[]
  trades           Trade[]

  @@index([creatorId])
  @@index([status])
  @@index([archivedAt])
  @@map("leagues")
}

model LeagueMember {
  id       String   @id @default(cuid())
  leagueId String
  userId   String
  joinedAt DateTime @default(now())

  league        League        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  roster        Roster?
  weeklyScores  WeeklyScore[]
  outgoingTrades Trade[]      @relation("TradeSenderMember")
  incomingTrades Trade[]      @relation("TradeRecipientMember")

  @@unique([leagueId, userId])
  @@index([leagueId])
  @@index([userId])
  @@map("league_members")
}

model Player {
  id       String     @id @default(cuid())
  name     String
  team     String
  region   Region
  role     PlayerRole
  imageUrl String?

  matchStats       PlayerMatchStats[]
  draftPicks       DraftPick[]
  rosterPlayers    RosterPlayer[]
  draftQueueEntries DraftQueueEntry[]

  @@index([region])
  @@index([role])
  @@index([team])
  @@map("players")
}

model PlayerMatchStats {
  id              String   @id @default(cuid())
  playerId        String
  externalMatchId String
  weekNumber      Int      @default(1)
  kills           Int
  deaths          Int
  assists         Int
  firstKills      Int
  firstDeaths     Int
  roundsWon       Int      @default(0)
  roundsLost      Int      @default(0)
  adr             Float
  acs             Float
  rating          Float
  hsPercent       Float
  kast            Float
  createdAt       DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, externalMatchId])
  @@index([playerId])
  @@index([externalMatchId])
  @@index([weekNumber])
  @@map("player_match_stats")
}

model DraftState {
  id               String      @id @default(cuid())
  leagueId         String      @unique
  status           DraftStatus @default(WAITING)
  currentRound     Int         @default(1)
  currentPickIndex Int         @default(0)
  draftOrder       Json
  turnExpiresAt    DateTime?
  startedAt        DateTime?
  completedAt      DateTime?

  league League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  picks  DraftPick[]

  @@index([status])
  @@index([turnExpiresAt])
  @@map("draft_states")
}

model DraftPick {
  id           String   @id @default(cuid())
  draftStateId String
  userId       String
  playerId     String
  round        Int
  pickNumber   Int
  isCaptain    Boolean  @default(false)
  slotType     SlotType
  pickedAt     DateTime @default(now())

  draftState DraftState @relation(fields: [draftStateId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])
  player     Player     @relation(fields: [playerId], references: [id])

  @@unique([draftStateId, pickNumber])
  @@index([draftStateId])
  @@index([userId])
  @@index([playerId])
  @@map("draft_picks")
}

model Roster {
  id             String @id @default(cuid())
  leagueMemberId String @unique
  leagueId       String

  leagueMember  LeagueMember   @relation(fields: [leagueMemberId], references: [id], onDelete: Cascade)
  league        League         @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  rosterPlayers RosterPlayer[]
  weeklyLineups WeeklyLineup[]

  @@index([leagueId])
  @@map("rosters")
}

model RosterPlayer {
  id         String   @id @default(cuid())
  rosterId   String
  playerId   String
  isCaptain  Boolean  @default(false)
  slotType   SlotType

  roster      Roster       @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  player      Player       @relation(fields: [playerId], references: [id])
  lineupSlots LineupSlot[]
  tradeItems  TradeItem[]

  @@unique([rosterId, playerId])
  @@index([rosterId])
  @@index([playerId])
  @@map("roster_players")
}

model LeagueWeek {
  id             String   @id @default(cuid())
  leagueId       String
  weekNumber     Int
  isLineupLocked Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, weekNumber])
  @@index([leagueId])
  @@index([weekNumber])
  @@map("league_weeks")
}

model WeeklyLineup {
  id         String  @id @default(cuid())
  rosterId   String
  weekNumber Int
  isLocked   Boolean @default(false)

  roster Roster       @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  slots  LineupSlot[]

  @@unique([rosterId, weekNumber])
  @@index([rosterId])
  @@index([weekNumber])
  @@map("weekly_lineups")
}

model LineupSlot {
  id             String  @id @default(cuid())
  weeklyLineupId String
  rosterPlayerId String
  isStarPlayer   Boolean @default(false)

  weeklyLineup WeeklyLineup @relation(fields: [weeklyLineupId], references: [id], onDelete: Cascade)
  rosterPlayer RosterPlayer @relation(fields: [rosterPlayerId], references: [id])

  @@unique([weeklyLineupId, rosterPlayerId])
  @@index([weeklyLineupId])
  @@index([rosterPlayerId])
  @@map("lineup_slots")
}

model WeeklyScore {
  id             String   @id @default(cuid())
  leagueMemberId String
  weekNumber     Int
  totalPoints    Float
  breakdown      Json

  leagueMember LeagueMember @relation(fields: [leagueMemberId], references: [id], onDelete: Cascade)

  @@unique([leagueMemberId, weekNumber])
  @@index([leagueMemberId])
  @@index([weekNumber])
  @@map("weekly_scores")
}

model DraftQueueEntry {
  id        String   @id @default(cuid())
  leagueId  String
  userId    String
  playerId  String
  priority  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId, playerId])
  @@unique([leagueId, userId, priority])
  @@index([leagueId, userId])
  @@map("draft_queue_entries")
}

model Trade {
  id           String      @id @default(cuid())
  leagueId     String
  fromMemberId String
  toMemberId   String
  status       TradeStatus @default(PENDING)
  note         String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  league     League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  fromMember LeagueMember @relation("TradeSenderMember", fields: [fromMemberId], references: [id], onDelete: Cascade)
  toMember   LeagueMember @relation("TradeRecipientMember", fields: [toMemberId], references: [id], onDelete: Cascade)
  items      TradeItem[]

  @@index([leagueId])
  @@index([fromMemberId])
  @@index([toMemberId])
  @@map("trades")
}

model TradeItem {
  id            String        @id @default(cuid())
  tradeId        String
  rosterPlayerId String
  side          TradeItemSide

  trade       Trade       @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  rosterPlayer RosterPlayer @relation(fields: [rosterPlayerId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@index([rosterPlayerId])
  @@map("trade_items")
}
